{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-loop-like-claude",
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "todowrite": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "dir*": "allow",
      "ls*": "allow",
      "pwd*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "pnpm test*": "allow",
      "pnpm lint*": "allow",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git reset*": "ask",
      "git clean*": "deny",
      "rm *": "deny",
      "del *": "ask",
      "rmdir *": "ask",
      "terraform destroy*": "deny"
    },
    "external_directory": "ask"
  }
}
