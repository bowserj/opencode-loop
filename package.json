{
  "name": "@bybrawe/opencode-loop",
  "version": "0.2.0",
  "description": "A Claude Code style loop plugin for OpenCode with interval/idle loops, compact schedules, safety flags, checkpoints, presets, watch mode and lifecycle controls.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "commands",
    "scripts",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "check": "node --check src/index.js",
    "install:global": "node scripts/install-node.mjs",
    "pack:zip": "node scripts/make-zip.mjs"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "loop",
    "ralph",
    "automation",
    "bybrawe",
    "compact",
    "checkpoint",
    "scheduler",
    "progress-md",
    "todo"
  ],
  "author": "Bybrawe",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  }
}
